{
  "manifest_version": 3,
  "name": "AutoDarts Plus",
  "version": "1.2.0",
  "description": "AutoDarts + enhances the experience for AutoDarts with new features",
  "author": "Timexo",

  "browser_specific_settings": {
    "gecko": {
      "id": "customize-darts@timexo.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://play.autodarts.io/*",
    "https://api.autodarts.io/*"
  ],

  "icons": {
    "16": "icon/16.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://play.autodarts.io/*"],
      "js": ["assets/pageScript.js-D_5Y7MLN.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://play.autodarts.io/*"],
      "js": [
        "assets/constants.js-CslvUQqv.js",
        "assets/tokenHelper.js-w9b0Kl2-.js",
        "assets/state.js-C1OI5esN.js",
        "assets/modals.js-jUSntdYx.js",
        "assets/logic.js-DFGemB9B.js",
        "assets/sync.js-C14uHNDl.js",
        "assets/matchbox.js-BawGxEYg.js",
        "assets/bracket.js-JOToDuGf.js",
        "assets/tables.js-g6zkb86a.js",
        "assets/setup.js-T4tm8Fi4.js",
        "assets/league.js-BtmeaPVy.js",
        "assets/groups.js-D-_F2Nh0.js",
        "assets/lobby.js-BLzlMqGV.js",
        "assets/actions.js-UyGtT4zT.js",
        "assets/renderer.js-tZ6b90Bg.js",
        "assets/content.js-m4yH4jg9.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
